{
  "openapi": "3.0.3",
  "info": {
    "title": "Agent Studio API - Instances",
    "version": "2.0.0",
    "description": "Agent Studio instance lifecycle and runtime context API."
  },
  "servers": [
    {
      "url": "https://api.agent-studio.io/v1",
      "description": "Production"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Instances",
      "description": "Agent instance lifecycle and runtime data"
    }
  ],
  "paths": {
    "/instances": {
      "get": {
        "tags": [
          "Instances"
        ],
        "summary": "List instances",
        "operationId": "listInstances",
        "parameters": [
          {
            "name": "modelId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of instances",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Instance"
                      }
                    },
                    "pagination": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  },
                  "required": [
                    "data",
                    "pagination"
                  ]
                }
              }
            }
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Instances"
        ],
        "summary": "Create instance",
        "operationId": "createInstance",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InstanceInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created instance",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Instance"
                }
              }
            }
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/instances/{instanceId}": {
      "get": {
        "tags": [
          "Instances"
        ],
        "summary": "Get instance detail",
        "operationId": "getInstance",
        "parameters": [
          {
            "name": "instanceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Instance detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Instance"
                }
              }
            }
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Instances"
        ],
        "summary": "Update instance",
        "operationId": "updateInstance",
        "parameters": [
          {
            "name": "instanceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InstanceInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated instance",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Instance"
                }
              }
            }
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Instances"
        ],
        "summary": "Delete instance",
        "operationId": "deleteInstance",
        "parameters": [
          {
            "name": "instanceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "default": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Pagination": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "example": 20
          },
          "offset": {
            "type": "integer",
            "example": 0
          },
          "total": {
            "type": "integer",
            "example": 100
          }
        },
        "required": [
          "limit",
          "offset",
          "total"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "example": "INVALID_INSTANCE_SCHEMA"
              },
              "message": {
                "type": "string",
                "example": "Instance schema validation failed."
              },
              "details": {
                "type": "object"
              }
            },
            "required": [
              "code",
              "message"
            ]
          }
        },
        "required": [
          "error"
        ]
      },
      "Binding": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "example": "plc_line_a"
          },
          "path": {
            "type": "string",
            "example": "ns=2;s=Ladle01.Temp"
          },
          "topic": {
            "type": "string",
            "example": "position/ladle/001"
          },
          "selector": {
            "type": "string",
            "example": "$.temperature"
          },
          "transform": {
            "type": "string",
            "example": "Math.round(value)"
          }
        },
        "required": [
          "source"
        ]
      },
      "GoalAssignment": {
        "type": "object",
        "properties": {
          "goalId": {
            "type": "string",
            "example": "safeHandling"
          },
          "status": {
            "type": "string",
            "example": "active"
          },
          "priority": {
            "type": "integer",
            "example": 100
          },
          "startedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "goalId",
          "status"
        ]
      },
      "PlanStep": {
        "type": "object",
        "properties": {
          "service": {
            "type": "string",
            "example": "moveTo"
          },
          "args": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": [
          "service"
        ]
      },
      "CurrentPlan": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "plan_20260411_001"
          },
          "planType": {
            "type": "string",
            "example": "deliveryAdjustment"
          },
          "status": {
            "type": "string",
            "example": "ready"
          },
          "summary": {
            "type": "string",
            "example": "先确认目标工位，再执行移动到 caster_2。"
          },
          "generatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "steps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PlanStep"
            }
          }
        },
        "required": [
          "id",
          "planType",
          "status"
        ]
      },
      "Instance": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "ladle_001"
          },
          "modelId": {
            "type": "string",
            "example": "ladle"
          },
          "state": {
            "type": "string",
            "example": "full"
          },
          "metadata": {
            "type": "object",
            "example": {
              "name": "ladle_001",
              "title": "1号钢包",
              "description": "转炉跨 1 号钢包实例",
              "version": "2.0.0"
            }
          },
          "attributes": {
            "type": "object",
            "example": {
              "capacity": 200,
              "maxTemperature": 1800,
              "insulationDuration": 120,
              "refractoryLife": 80
            }
          },
          "variables": {
            "type": "object",
            "example": {
              "steelAmount": 150,
              "temperature": 1650,
              "currentLocation": "converter_1",
              "targetLocation": "caster_2",
              "processStatus": "awaiting_transport"
            }
          },
          "bindings": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/Binding"
            },
            "example": {
              "temperature": {
                "source": "plc_line_a",
                "path": "ns=2;s=Ladle01.Temp",
                "selector": "$.temperature",
                "transform": "Math.round(value)"
              }
            }
          },
          "memory": {
            "type": "object",
            "example": {
              "currentAssignment": {
                "taskId": "task_20260411_001",
                "destination": "caster_2"
              },
              "lastDecision": {
                "mode": "cortex",
                "summary": "优先送达 caster_2"
              }
            }
          },
          "activeGoals": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GoalAssignment"
            }
          },
          "currentPlan": {
            "$ref": "#/components/schemas/CurrentPlan"
          },
          "extensions": {
            "type": "object"
          }
        },
        "required": [
          "id",
          "modelId",
          "state",
          "variables"
        ]
      },
      "InstanceInput": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "ladle_001"
          },
          "modelId": {
            "type": "string",
            "example": "ladle"
          },
          "state": {
            "type": "string",
            "example": "full"
          },
          "metadata": {
            "type": "object"
          },
          "attributes": {
            "type": "object"
          },
          "variables": {
            "type": "object"
          },
          "bindings": {
            "type": "object"
          },
          "memory": {
            "type": "object"
          },
          "activeGoals": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GoalAssignment"
            }
          },
          "currentPlan": {
            "$ref": "#/components/schemas/CurrentPlan"
          },
          "extensions": {
            "type": "object"
          }
        },
        "required": [
          "id",
          "modelId"
        ]
      }
    }
  }
}
