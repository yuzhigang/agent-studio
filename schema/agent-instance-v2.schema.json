{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-studio.io/schema/agent-instance-v2.schema.json",
  "title": "Agent Studio Agent Instance v2",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://agent-studio.io/schema/v2/instance"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "modelId": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "attributes": {
      "$ref": "#/$defs/valueMap"
    },
    "variables": {
      "$ref": "#/$defs/valueMap"
    },
    "bindings": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/binding"
      }
    },
    "memory": {
      "type": "object",
      "additionalProperties": true
    },
    "activeGoals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/goalAssignment"
      }
    },
    "currentPlan": {
      "$ref": "#/$defs/currentPlan"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "$schema",
    "id",
    "modelId",
    "state",
    "metadata",
    "variables"
  ],
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "creator": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "title"
      ]
    },
    "scalarValue": {
      "type": [
        "string",
        "number",
        "integer",
        "boolean",
        "null"
      ]
    },
    "runtimeObject": {
      "type": "object",
      "additionalProperties": true,
      "not": {
        "required": [
          "bind"
        ]
      }
    },
    "runtimeValue": {
      "oneOf": [
        {
          "$ref": "#/$defs/scalarValue"
        },
        {
          "type": "array"
        },
        {
          "$ref": "#/$defs/runtimeObject"
        }
      ]
    },
    "valueMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/runtimeValue"
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "selector": {
          "type": "string"
        },
        "transform": {
          "type": "string"
        },
        "refreshSeconds": {
          "type": "number"
        }
      },
      "required": [
        "source"
      ]
    },
    "goalAssignment": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "goalId": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "priority": {
          "type": "integer"
        },
        "startedAt": {
          "type": "string"
        }
      },
      "required": [
        "goalId",
        "status"
      ]
    },
    "planStep": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "service": {
          "type": "string"
        },
        "args": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "service"
      ]
    },
    "currentPlan": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "planType": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "generatedAt": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/planStep"
          }
        }
      },
      "required": [
        "id",
        "planType",
        "status"
      ]
    }
  }
}
