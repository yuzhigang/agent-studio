{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-studio.io/schema/agent-model-v2.schema.json",
  "title": "Agent Studio Agent Model v2",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://agent-studio.io/schema/v2"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "attributes": {
      "$ref": "#/$defs/fieldDefinitions"
    },
    "variables": {
      "$ref": "#/$defs/fieldDefinitions"
    },
    "derivedProperties": {
      "$ref": "#/$defs/namedObjects"
    },
    "rules": {
      "$ref": "#/$defs/namedObjects"
    },
    "functions": {
      "$ref": "#/$defs/namedObjects"
    },
    "services": {
      "$ref": "#/$defs/namedObjects"
    },
    "states": {
      "$ref": "#/$defs/namedObjects"
    },
    "transitions": {
      "$ref": "#/$defs/namedObjects"
    },
    "behaviors": {
      "$ref": "#/$defs/namedObjects"
    },
    "events": {
      "$ref": "#/$defs/namedObjects"
    },
    "alarms": {
      "$ref": "#/$defs/namedObjects"
    },
    "schedules": {
      "$ref": "#/$defs/namedObjects"
    },
    "goals": {
      "$ref": "#/$defs/namedObjects"
    },
    "decisionPolicies": {
      "$ref": "#/$defs/namedObjects"
    },
    "memory": {
      "$ref": "#/$defs/namedObjects"
    },
    "plans": {
      "$ref": "#/$defs/namedObjects"
    }
  },
  "required": [
    "$schema",
    "metadata"
  ],
  "dependentRequired": {
    "transitions": [
      "states"
    ],
    "decisionPolicies": [
      "goals",
      "memory",
      "plans"
    ]
  },
  "allOf": [
    {
      "anyOf": [
        {
          "required": [
            "attributes"
          ]
        },
        {
          "required": [
            "variables"
          ]
        },
        {
          "required": [
            "services"
          ]
        },
        {
          "required": [
            "goals"
          ]
        }
      ]
    }
  ],
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "version": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "group": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "creator": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "title"
      ]
    },
    "namedObjects": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "fieldDefinitions": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/fieldDefinition"
      }
    },
    "fieldDefinition": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "default": {},
        "nullable": {
          "type": "boolean"
        },
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        },
        "enum": {
          "type": "array"
        },
        "items": {
          "type": "object"
        },
        "schema": {
          "type": "object"
        },
        "x-unit": {
          "type": "string"
        },
        "x-rules": {
          "type": "object"
        }
      },
      "required": [
        "type"
      ]
    }
  }
}
