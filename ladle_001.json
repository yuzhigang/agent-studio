{
    "$schema": "https://agent-studio.io/schema/v1",
    "id": "ladle_001",
    "state": "empty",
    "metadata": {
        "name": "ladle",
        "title": "1号钢包",
        "description": "这是一个钢包的数字孪生，包含了钢包的基本属性、实时变量、派生属性等信息，可以用于监控和分析钢包的状态和性能。",
        "tags": [
            "steelmaking",
            "ladle"
        ],
        "creator": "张三",
        "createdAt": "2024-06-01T10:00:00Z",
        "updatedAt": "2024-06-01T10:00:00Z",
        "kind": "ladle",
        "version": "1.0.0"
    },
    "attributes": {
        "capacity": {
            "title": "冷却水流量",
            "unit": "L/min",
            "description": "钢包冷却系统水流量",
            "value": 150,
            "isCustom": true
        },
        "maxTemperature": {
            "title": "冷却水流量",
            "unit": "L/min",
            "description": "钢包冷却系统水流量",
            "value": 150
        }
    },
    "variables": {
        "steelAmount": {
            "title": "冷却水流量",
            "unit": "L/min",
            "description": "钢包冷却系统水流量",
            "value": 150,
            "isCustom": false,
            "bind": {
                "source": "plc_line_a",
                "path": "ns=2;s=Ladle01.Weight",
                "selector": "$.value",
                "transform": "value * 0.001"
            }
        },
        "temperature": {
            "value": 1650,
            "bind": {
                "source": "plc_line_a",
                "path": "ns=2;s=Ladle01.Temp",
                "selector": "$.temperature",
                "transform": "Math.round(value)"
            }
        },
        "carbonContent": {
            "value": 0.15,
            "bind": {
                "source": "mes_system",
                "path": "/ladles/001/analysis",
                "selector": "$.chemical.carbon.percent",
                "transform": "parseFloat(value.toFixed(3))"
            }
        },
        "steelGrade": {
            "value": "Q235B",
            "bind": {
                "source": "mes_system",
                "path": "/ladles/001/grade",
                "selector": "$.grade.name",
                "transform": "value.toUpperCase()"
            }
        },
        "currentLocation": {
            "value": "converter_1",
            "bind": {
                "source": "factory_mqtt",
                "topic": "position/ladle/001",
                "selector": "$.position.zone",
                "transform": "value.toLowerCase().replace(/\\s/g, '_')"
            }
        },
        "locationX": {
            "value": 1250.5,
            "bind": {
                "source": "factory_mqtt",
                "topic": "position/ladle/001",
                "selector": "$.position.x",
                "transform": "value / 1000"
            }
        },
        "locationY": {
            "value": 3680.0,
            "bind": {
                "source": "factory_mqtt",
                "topic": "position/ladle/001",
                "selector": "$.position.y",
                "transform": "value / 1000"
            }
        },
        "status": {
            "value": "full",
            "bind": {
                "source": "factory_mqtt",
                "topic": "status/ladle/001",
                "selector": "$.state.current",
                "transform": "value"
            }
        },
        "usageCount": {
            "value": 45,
            "bind": {
                "source": "mes_system",
                "path": "/ladles/001/maintenance",
                "selector": "$.cycles.completed",
                "transform": "parseInt(value)"
            }
        },
        "lastMaintenanceTime": {
            "value": "2025-03-15T08:30:00Z",
            "bind": {
                "source": "mes_system",
                "path": "/ladles/001/maintenance",
                "selector": "$.lastMaintenance.timestamp",
                "transform": "new Date(value).toISOString()"
            }
        },
        "tiltAngle": {
            "value": 0,
            "bind": {
                "source": "plc_line_a",
                "path": "ns=2;s=Ladle01.Tilt.Angle",
                "selector": "$.angle.degrees",
                "transform": "Math.max(-90, Math.min(90, value))"
            }
        },
        "isLidClosed": {
            "value": true,
            "bind": {
                "source": "plc_line_a",
                "path": "ns=2;s=Ladle01.Lid.Status",
                "selector": "$.sensors.lidSwitch",
                "transform": "value === 1 || value === true"
            }
        }
    },
    "derivedProperties": {
        "steelAmount1": {
            "title": "冷却水流量",
            "unit": "L/min",
            "description": "钢包冷却系统水流量",
            "value": 150,
            "isCustom": false
        }
    },
    "extensions": {
        "attributes": {},
        "variables": {},
        "derivedProperties": {},
        "functions": {},
        "services": {},
        "alarms": {},
        "behaviors": {},
        "schedules": {}
    }
}